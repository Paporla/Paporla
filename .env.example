# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=tu_url_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# RESEND (EMAILS)
RESEND_API_KEY=re_tu_api_key_aqui
RESEND_FROM_EMAIL=noreply@paporla.com

# URL DEL SITIO
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GOOGLE ANALYTICS (opcional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# SENTRY (monitoreo de errores - opcional)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxx.ingest.sentry.io/xxxxxx
SENTRY_ORG=tu-org
SENTRY_PROJECT=paporla

# CRON SECRET (protege endpoints de cron)
# Generar con: openssl rand -hex 32
CRON_SECRET=tu_secret_aqui

# MANTENIMIENTO
NEXT_PUBLIC_MAINTENANCE_MODE=false
